# SDG Assessment Tool - Local Development Environment
# Copy this file to .env before running docker-compose
# cp .env.example .env

# Flask
FLASK_ENV=development
SECRET_KEY=dev-secret-key-change-in-production

# Database
POSTGRES_USER=sdg_user
POSTGRES_PASSWORD=sdg_password
POSTGRES_DB=sdg_assessment_dev

# Email (prints to console in dev — no real SMTP needed)
MAIL_SERVER=localhost
MAIL_PORT=1025
MAIL_USE_TLS=False
MAIL_USERNAME=
MAIL_PASSWORD=
